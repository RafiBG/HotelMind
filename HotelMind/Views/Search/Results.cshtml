@section Styles {
    <link rel="stylesheet" href="~/css/weather.css" asp-append-version="true" />
}

<div class="container main-dashboard mt-4">
    <div class="ai-badge text-primary fw-bold mb-2"><i class="bi bi-robot"></i> AI INSIGHTS</div>
    <h2 style="color: var(--text-color);">Assisting with: "@ViewBag.UserQuery"</h2>
    <hr style="border-color: var(--border-color);" />

    <div class="dashboard-flex">
        <div class="packing-column d-flex flex-column gap-3">
            
            <div id="packingWidget" class="weather-card shadow-sm p-3" style="display: none; border-top: 4px solid #4da3ff; background-color: var(--nav-bg); border-radius: 12px; border: 1px solid var(--border-color);">
                <div class="small-label mb-3" style="color: var(--nav-text); font-weight: bold; font-size: 0.85rem;"><i class="bi bi-briefcase"></i> WHAT TO PACK</div>
                <div id="packingList" class="d-flex flex-wrap gap-2">
                </div>
                <div class="mt-3" style="font-size: 0.75rem; color: var(--nav-text); font-style: italic;">
                    <span id="packing-context"></span>
                </div>
            </div>

            <div id="vibeWidget" class="weather-card shadow-sm p-3" style="display: none; border-top: 4px solid #ff9f43; background-color: var(--nav-bg); border-radius: 12px; border: 1px solid var(--border-color);">
                <div class="small-label mb-2" style="color: var(--nav-text); font-weight: bold; font-size: 0.85rem;"><i class="bi bi-stars"></i> LOCAL VIBE</div>
                <div id="vibe-content" style="font-size: 0.9rem; line-height: 1.5; color: var(--text-color);">
                </div>
            </div>
            
        </div>

        <div class="ai-main-response d-flex flex-column" style="flex: 1; min-width: 0;">
            <div id="chatWindow" style="max-height: 600px; overflow-y: auto; padding-right: 10px; margin-bottom: 15px;">
                <div class="ai-response-container p-4 glass-card shadow-sm" style="background-color: var(--nav-bg); border: 1px solid var(--border-color); border-radius: 12px; color: var(--text-color);">
                    <div style="white-space: pre-wrap; font-size: 1.05rem; line-height: 1.6;">@ViewBag.Response</div>
                </div>
            </div>

            <div id="aiTyping" class="text-primary small mb-2 fw-bold" style="display:none;">
                <span class="spinner-grow spinner-grow-sm me-1"></span> HotelMind is thinking...
            </div>

            <div class="chat-input-box p-2 d-flex gap-2 align-items-center shadow-sm" style="background-color: var(--nav-bg); border: 1px solid var(--border-color); border-radius: 12px;">
                <input type="text" id="chatInput" class="form-control border-0" placeholder="Ask a follow-up..." style="background-color: var(--input-bg); color: var(--input-text); box-shadow: none;" />
                <button onclick="sendChatMessage()" class="btn btn-primary d-flex align-items-center justify-content-center" title="Send Message" style="border-radius: 8px; width: 45px; height: 45px;">
                    <i class="bi bi-send-fill text-white"></i>
                </button>
            </div>
        </div>

        <div id="weatherSidebar" class="weather-column">
            <div id="weatherWidget" class="weather-card shadow-sm p-3" style="background-color: var(--nav-bg); border: 1px solid var(--border-color); border-radius: 12px; color: var(--text-color);">
                <div class="weather-header d-flex justify-content-between align-items-center mb-2">
                    <span class="small-label" id="w-location" style="color: var(--nav-text); font-weight: bold; font-size: 0.85rem;">LOCATION CLIMATE</span>
                    <img id="w-icon" src="" alt="" style="width: 50px;">
                </div>
                <div id="w-temp" class="weather-temp fw-bold" style="font-size: 2.5rem; color: var(--text-color);">--°C</div>
                <div id="w-desc" class="weather-text text-capitalize" style="color: var(--nav-text); font-size: 1.1rem;">Analyzing...</div>
                
                <div id="forecastList" class="forecast-container mt-4"></div>
                
                <div class="ai-recommendation mt-4 p-2 rounded" id="w-advice" style="background-color: var(--bg-color); color: var(--text-color); font-size: 0.9rem; border: 1px solid var(--border-color);">
                    ...
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const city = extractCity("@ViewBag.UserQuery");
        if (city && city.length > 2) loadDashboardData(city);
    });

    function extractCity(text) {
        const match = text.match(/(?:in|at)\s+([A-Z][a-z]+)/i);
        return match ? match[1] : text.trim().split(' ').pop().replace(/[?.!]/g, "");
    }

    async function loadDashboardData(city) {
        try {
            const response = await fetch(`/api/weather/${encodeURIComponent(city)}`);
            const data = await response.json();

            // 1. Fill Weather UI
            document.getElementById('w-location').innerText = `${data.location.name.toUpperCase()}`;
            document.getElementById('w-icon').src = "https:" + data.current.condition.icon;
            document.getElementById('w-temp').innerText = `${Math.round(data.current.temp_c)}°C`;
            document.getElementById('w-desc').innerText = data.current.condition.text;

            // 2. Forecast Display (Updated JS styles to use CSS variables)
            let forecastHtml = "";
            data.forecast.forecastday.forEach(day => {
                forecastHtml += `<div class="d-flex justify-content-between py-2 border-bottom" style="font-size: 0.9rem; border-color: var(--border-color) !important;">
                    <span style="color: var(--text-color);">${new Date(day.date).toLocaleDateString('en-US', {weekday:'short'})}</span>
                    <img src="https:${day.day.condition.icon}" width="24"/>
                    <span style="color: var(--text-color);">${Math.round(day.day.maxtemp_c)}° / <small class="temp-min" style="color: var(--nav-text);">${Math.round(day.day.mintemp_c)}°</small></span>
                </div>`;
            });
            document.getElementById('forecastList').innerHTML = forecastHtml;
            document.getElementById('weatherWidget').classList.add('show');

            // 3. AI Weather Tip
            let advice = "Enjoy your trip!";
            if (data.current.temp_c > 28) advice = "Hot weather—stay hydrated.";
            if (data.current.condition.text.includes("Rain")) advice = "Carry an umbrella.";
            document.getElementById('w-advice').innerText = `AI Tip: ${advice}`;

            // --- SMART DATA CAPTURE FOR AI ---
            const today = data.forecast.forecastday[0].day;
            const high = today.maxtemp_c;
            const low = today.mintemp_c;
            const condition = data.current.condition.text;

            // 4. FETCH SMART PACKING
            fetch(`/Search/GetPackingAdvice?city=${city}&weather=${condition}&highTemp=${high}&lowTemp=${low}`)
                .then(res => res.json())
                .then(aiData => {
                    if (aiData.advice) {
                        const items = aiData.advice.split(',');
                        // Styled the packing badges to look good in dark mode
                        document.getElementById('packingList').innerHTML = items.map(i => `<span class="badge" style="background-color: var(--bg-color); color: var(--text-color); border: 1px solid var(--border-color); padding: 8px 12px; font-weight: normal;">${i.trim()}</span>`).join('');
                        document.getElementById('packing-context').innerText = `Advice for ${Math.round(low)}°C to ${Math.round(high)}°C`;
                        document.getElementById('packingWidget').style.display = 'block';
                    }
                });

            // 5. FETCH CITY VIBE
            fetch(`/Search/GetCityVibe?city=${encodeURIComponent(city)}`)
                .then(res => res.json())
                .then(vibeData => {
                    if (vibeData.vibe) {
                        document.getElementById('vibe-content').innerText = vibeData.vibe;
                        document.getElementById('vibeWidget').style.display = 'block';
                    }
                });

        } catch (e) { console.error("Data load error", e); }
    }

    async function sendChatMessage() {
        const input = document.getElementById('chatInput');
        const msg = input.value;
        if(!msg) return;

        const chatWindow = document.getElementById('chatWindow');
        // Swapped to standard Bootstrap primary badge for user messages
        chatWindow.innerHTML += `<div class="text-end mb-3"><span class="badge bg-primary px-3 py-2 fs-6 rounded-pill shadow-sm">${msg}</span></div>`;
        input.value = '';
        document.getElementById('aiTyping').style.display = 'block';

        try {
            const response = await fetch('/Search/Chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: msg })
            });
            const data = await response.json();
            // Appended the AI response using the correct theme variables
            chatWindow.innerHTML += `<div class="ai-response-container p-4 glass-card mb-3 shadow-sm" style="background-color: var(--nav-bg); border: 1px solid var(--border-color); border-radius: 12px; color: var(--text-color); white-space: pre-wrap; font-size: 1.05rem; line-height: 1.6;">${data.response}</div>`;
            chatWindow.scrollTop = chatWindow.scrollHeight;
        } finally { document.getElementById('aiTyping').style.display = 'none'; }
    }
</script>