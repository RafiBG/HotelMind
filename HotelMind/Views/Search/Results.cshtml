@section Styles {
    <link rel="stylesheet" href="~/css/weather.css" asp-append-version="true" />
}

<div class="container main-dashboard">
    <div class="ai-badge"><i class="bi bi-robot"></i> AI INSIGHTS</div>
    <h2>Assisting with: "@ViewBag.UserQuery"</h2>
    <hr />

    <div class="dashboard-flex">
        <div class="packing-column d-flex flex-column gap-3">
            <div id="packingWidget" class="weather-card" style="display: none; border-top: 4px solid #4da3ff;">
                <div class="small-label mb-3"><i class="bi bi-briefcase"></i> WHAT TO PACK</div>
                <div id="packingList" class="d-flex flex-column gap-2">
                </div>
                <div class="mt-3" style="font-size: 0.7rem; color: #888; font-style: italic;">
                    <span id="packing-context"></span>
                </div>
            </div>

            <div id="vibeWidget" class="weather-card" style="display: none; border-top: 4px solid #ff9f43; background: rgba(255, 255, 255, 0.95);">
                <div class="small-label mb-2"><i class="bi bi-stars"></i> LOCAL VIBE</div>
                <div id="vibe-content" style="font-size: 0.85rem; line-height: 1.4; color: #2d3436;">
                </div>
            </div>
        </div>

        <div class="ai-main-response">
            <div id="chatWindow" style="max-height: 600px; overflow-y: auto; padding-right: 10px;">
                <div class="ai-response-container p-4 glass-card mb-3">
                    <div style="white-space: pre-wrap;">@ViewBag.Response</div>
                </div>
            </div>

            <div id="aiTyping" class="text-info small mb-2" style="display:none;">
                <span class="spinner-grow spinner-grow-sm"></span> HotelMind is thinking...
            </div>

            <div class="chat-input-box glass-card p-2 d-flex gap-2">
                <input type="text" id="chatInput" class="form-control" placeholder="Ask a follow-up..." />
                <button onclick="sendChatMessage()" class="btn-send-simple" title="Send Message">
                    <img src="https://img.icons8.com/ios-filled/50/paper-plane.png" alt="send" />
                </button>
            </div>
        </div>

        <div id="weatherSidebar" class="weather-column">
            <div id="weatherWidget" class="weather-card">
                <div class="weather-header">
                    <span class="small-label" id="w-location">LOCATION CLIMATE</span>
                    <img id="w-icon" src="" alt="">
                </div>
                <div id="w-temp" class="weather-temp">--°C</div>
                <div id="w-desc" class="weather-text">Analyzing...</div>
                <div id="forecastList" class="forecast-container mt-3"></div>
                <div class="ai-recommendation mt-3" id="w-advice">...</div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const city = extractCity("@ViewBag.UserQuery");
        if (city && city.length > 2) loadDashboardData(city);
    });

    function extractCity(text) {
        const match = text.match(/(?:in|at)\s+([A-Z][a-z]+)/i);
        return match ? match[1] : text.trim().split(' ').pop().replace(/[?.!]/g, "");
    }

    async function loadDashboardData(city) {
        try {
            const response = await fetch(`/api/weather/${encodeURIComponent(city)}`);
            const data = await response.json();

            // 1. Fill Weather UI
            document.getElementById('w-location').innerText = `${data.location.name.toUpperCase()}`;
            document.getElementById('w-icon').src = "https:" + data.current.condition.icon;
            document.getElementById('w-temp').innerText = `${Math.round(data.current.temp_c)}°C`;
            document.getElementById('w-desc').innerText = data.current.condition.text;

            // 2. Forecast Display
            let forecastHtml = "";
            data.forecast.forecastday.forEach(day => {
                forecastHtml += `<div class="d-flex justify-content-between py-1 border-bottom" style="font-size: 0.8rem;">
                    <span>${new Date(day.date).toLocaleDateString('en-US', {weekday:'short'})}</span>
                    <img src="https:${day.day.condition.icon}" width="20"/>
                    <span>${Math.round(day.day.maxtemp_c)}° / <small class="temp-min" style="color:#888;">${Math.round(day.day.mintemp_c)}°</small></span>
                </div>`;
            });
            document.getElementById('forecastList').innerHTML = forecastHtml;
            document.getElementById('weatherWidget').classList.add('show');

            // 3. AI Weather Tip
            let advice = "Enjoy your trip!";
            if (data.current.temp_c > 28) advice = "Hot weather—stay hydrated.";
            if (data.current.condition.text.includes("Rain")) advice = "Carry an umbrella.";
            document.getElementById('w-advice').innerText = `AI Tip: ${advice}`;

            // --- SMART DATA CAPTURE FOR AI ---
            const today = data.forecast.forecastday[0].day;
            const high = today.maxtemp_c;
            const low = today.mintemp_c;
            const condition = data.current.condition.text;

            // 4. FETCH SMART PACKING (Uses High/Low range)
            fetch(`/Search/GetPackingAdvice?city=${city}&weather=${condition}&highTemp=${high}&lowTemp=${low}`)
                .then(res => res.json())
                .then(aiData => {
                    if (aiData.advice) {
                        const items = aiData.advice.split(',');
                        document.getElementById('packingList').innerHTML = items.map(i => `<div class="badge-packing">${i.trim()}</div>`).join('');
                        document.getElementById('packing-context').innerText = `Advice for ${Math.round(low)}°C to ${Math.round(high)}°C`;
                        document.getElementById('packingWidget').style.display = 'block';
                    }
                });

            // 5. FETCH CITY VIBE
            fetch(`/Search/GetCityVibe?city=${encodeURIComponent(city)}`)
                .then(res => res.json())
                .then(vibeData => {
                    if (vibeData.vibe) {
                        document.getElementById('vibe-content').innerText = vibeData.vibe;
                        document.getElementById('vibeWidget').style.display = 'block';
                    }
                });

        } catch (e) { console.error("Data load error", e); }
    }

    async function sendChatMessage() {
        const input = document.getElementById('chatInput');
        const msg = input.value;
        if(!msg) return;

        const chatWindow = document.getElementById('chatWindow');
        chatWindow.innerHTML += `<div class="text-end mb-3"><span class="badge bg-primary p-2">${msg}</span></div>`;
        input.value = '';
        document.getElementById('aiTyping').style.display = 'block';

        try {
            const response = await fetch('/Search/Chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: msg })
            });
            const data = await response.json();
            chatWindow.innerHTML += `<div class="ai-response-container p-4 glass-card mb-3">${data.response}</div>`;
            chatWindow.scrollTop = chatWindow.scrollHeight;
        } finally { document.getElementById('aiTyping').style.display = 'none'; }
    }
</script>