@model HotelMind.Models.LoginDBModel

@{
    ViewData["Title"] = "Login";
}

<div class="auth-container shadow-sm">
    <div class="auth-header">
        <h2>Login to HotelMind</h2>
        <p style="color: var(--nav-text);">Welcome back! Please enter your details.</p>
    </div>

    <form asp-action="Login" method="post">
        <div asp-validation-summary="All" class="text-danger small mb-3"></div>
        
        <div class="form-group mb-3">
            <label asp-for="Email" class="form-label fw-bold"></label>
            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
        </div>
        
        <div class="form-group mb-4">
            <label asp-for="Password" class="form-label fw-bold"></label>
            <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
        </div>
        
        <button type="submit" class="btn btn-primary btn-auth w-100">Login</button>

        <div class="text-center mt-4" style="color: var(--nav-text); font-size: 0.9rem;">
            Don't have an account? <a asp-controller="Account" asp-action="Register" class="text-primary text-decoration-none fw-bold">Register</a>
        </div>
    </form>
</div>